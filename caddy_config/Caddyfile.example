automation.yourdomain.com {
    reverse_proxy n8n:5678 {
      flush_interval -1
    }
}

flowise.yourdomain.com {
    reverse_proxy flowise:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Homepage dashboard (homepage install only)
dashboard.yourdomain.com {
    reverse_proxy homepage:3000
}

# Grafana monitoring (monitoring/pro install only)
monitoring.yourdomain.com {
    reverse_proxy grafana:3000
}

# Portainer (pro install only)
portainer.yourdomain.com {
    reverse_proxy portainer:9443 {
        transport http {
            tls_insecure_skip_verify
        }
    }
}

# Uptime Kuma (pro install only)
uptime.yourdomain.com {
    reverse_proxy uptime-kuma:3001
}

# Nango OAuth management (optional - requires docker-compose-nango.yml)
nango.yourdomain.com {
    reverse_proxy nango-server:3003 {
        flush_interval -1
    }
}
