# 🌐 Domaine configuration
DATA_FOLDER=.
DOMAIN_NAME=yourdomain.com
SUBDOMAIN=automation
GENERIC_TIMEZONE=Europe/Paris
SSL_EMAIL=your-email@example.com

# 🔐 n8n authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-secure-password

# 🤖 Flowise
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=your-secure-password

# 📊 Grafana (if already installed with monitoring or pro options)
GRAFANA_PASSWORD=your-secure-password

# 🏠 Homepage (if installed with homepage option)
HOMEPAGE_USERNAME=admin
HOMEPAGE_PASSWORD=your-secure-password

# 🔗 Nango (OAuth Management - optional, requires docker-compose-nango.yml)
# Run: docker compose -f docker-compose-nango.yml up -d
# NANGO_SUBDOMAIN=nango
# NANGO_ENCRYPTION_KEY=your-base64-encoded-key  # Generate: openssl rand -base64 32
# NANGO_DB_PASSWORD=your-secure-password
# NANGO_DASHBOARD_USERNAME=admin
# NANGO_DASHBOARD_PASSWORD=your-secure-password
# SMTP for Nango email auth (required when FLAG_AUTH_ENABLED=true)
# Format: smtp://user:password@host:port  (smtps:// for port 465)
# NANGO_SMTP_URL=smtp://resend:your-resend-api-key@smtp.resend.com:587
# NANGO_SMTP_FROM=nango@your-resend-verified-domain.com

# 🔄 Watchtower notifications (optional for pro install)
# Uncomment and configure these variables to enable email notifications for Watchtower.
# WATCHTOWER_NOTIFICATIONS=email
# SMTP_SERVER=your.smtp.server.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# WATCHTOWER_NOTIFICATION_EMAIL_FROM=${SSL_EMAIL} # Reuses the SSL_EMAIL for sender
# WATCHTOWER_NOTIFICATION_EMAIL_TO=${SSL_EMAIL}   # Reuses the SSL_EMAIL for recipient

# 💡 Notes:
# - These values are examples
# - Use setup.sh script to automatically generate secure passwords
# - The script will replace or create your server .env file with good values
